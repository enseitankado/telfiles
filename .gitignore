# Secrets / environment
.env
.env.local

# Generated at install time by install.sh — records the HEAD SHA so /api/version
# can tell the user when a newer commit exists on origin/main.
app/version.json

# Local runtime data (Telegram sessions, UI auth, user DB, downloads)
data/
downloads/
pgdata/

# Telemetry server runtime data (auto-created on first POST)
telemetry-server/data/

# Local dev / tooling
.claude/
.vscode/
.idea/

# Python build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# OS
.DS_Store
Thumbs.db
